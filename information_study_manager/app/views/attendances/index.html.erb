<h1 class="page-title">出席一覧</h1>

<% if notice.present? %>
  <div class="flash flash--notice"><%= notice %></div>
<% end %>
<% if alert.present? %>
  <div class="flash flash--alert"><%= alert %></div>
<% end %>

<div class="panel">
  <div class="panel-head">
    <h2>絞り込み</h2>
    <%= link_to "リセット", attendances_path, class: "btn ghost btn--sm" %>
  </div>
  <div class="panel-body">
    <%= search_form_for @q, url: attendances_path,
          html: { data: { controller: "autosubmit" } } do |f| %>
      <div class="filter-form">
        <div class="filter-row">
          <div class="filter-field">
            <%= f.label :student_code_eq, "学籍番号" %>
            <%= f.select :student_code_eq, @student_codes,
                  { include_blank: "すべて" },
                  { data: { action: "change->autosubmit#change" } } %>
          </div>
          <div class="filter-field">
            <%= f.label :lesson_code_eq, "授業コード" %>
            <%= f.select :lesson_code_eq, @lesson_codes,
                  { include_blank: "すべて" },
                  { data: { action: "change->autosubmit#change" } } %>
          </div>
        </div>
        <div class="filter-row filter-row--center">
          <div class="filter-field filter-field--status">
            <%= f.label :status_eq, "状態" %>
            <%= f.select :status_eq,
                  Attendance.statuses.map { |k, v| [t("attendance.status.#{k}"), v] },
                  { include_blank: "すべて" },
                  { data: { action: "change->autosubmit#change" } } %>
          </div>
          <div class="filter-field filter-field--date">
            <%= f.label :date_eq, "授業日" %>
            <%= f.date_field :date_eq,
                  data: { action: "change->autosubmit#change" } %>
          </div>
          <div class="filter-field filter-field--date">
            <%= f.label :created_on, "送信日" %>
            <%= f.date_field :created_on,
                  data: { action: "change->autosubmit#change" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="panel">
  <div class="panel-head">
    <h2>レコード一覧</h2>
    <span style="font-size:13px; color:var(--text-sub);"><%= @attendances.size %> 件</span>

    <%# ─── 一括作成ボタン＆モーダル ─── %>
    <div data-controller="bulk-create">
      <button type="button"
              class="btn ghost btn--sm"
              data-action="click->bulk-create#open">一括作成</button>

      <div data-bulk-create-target="modal"
           class="modal-overlay hidden"
           data-action="click->bulk-create#backdropClose">
        <div class="modal" data-action="click->bulk-create#stopPropagation">

          <%# ── STEP 1: 入力フォーム ── %>
          <div data-bulk-create-target="step1">
            <h3 class="modal-title">出席レコードの一括作成</h3>
            <p class="modal-desc">出席番号は「1-40」や「1,5,10」など範囲・個別・組み合わせで入力できます。</p>
            <div class="bulk-create-form">
              <div class="bulk-create-row">
                <div class="filter-field">
                  <label for="bc-lesson-code">授業コード</label>
                  <input id="bc-lesson-code"
                         type="text"
                         list="bc-lesson-code-list"
                         placeholder="例: 25R-INFO-01"
                         required
                         data-bulk-create-target="lessonCode">
                  <datalist id="bc-lesson-code-list">
                    <% @lesson_codes.each do |code| %>
                      <option value="<%= code %>">
                    <% end %>
                  </datalist>
                </div>
                <div class="filter-field filter-field--date">
                  <label for="bc-date">授業日</label>
                  <input id="bc-date"
                         type="date"
                         value="<%= Date.current.iso8601 %>"
                         required
                         data-bulk-create-target="date">
                </div>
              </div>
              <div class="bulk-create-row">
                <div class="filter-field">
                  <label for="bc-student-codes">出席番号</label>
                  <input id="bc-student-codes"
                         type="text"
                         placeholder="例: 1-40 または 1,3,5,10-15"
                         required
                         data-bulk-create-target="studentCodes">
                </div>
                <div class="filter-field filter-field--status">
                  <label for="bc-status">状態</label>
                  <select id="bc-status" required data-bulk-create-target="status">
                    <% Attendance.statuses.each_key do |key| %>
                      <option value="<%= key %>" <%= "selected" if key == "present" %>>
                        <%= t("attendance.status.#{key}") %>
                      </option>
                    <% end %>
                  </select>
                </div>
              </div>
              <div class="bulk-create-row">
                <div class="filter-field">
                  <label for="bc-comment">備考（任意）</label>
                  <input id="bc-comment"
                         type="text"
                         placeholder="メモがあれば"
                         data-bulk-create-target="comment">
                </div>
              </div>
            </div>
            <div class="modal-actions">
              <button type="button"
                      class="btn ghost"
                      data-action="click->bulk-create#close">キャンセル</button>
              <button type="button"
                      class="btn primary"
                      data-action="click->bulk-create#preview">プレビュー →</button>
            </div>
          </div>

          <%# ── STEP 2: 確認プレビュー ── %>
          <div data-bulk-create-target="step2" style="display:none">
            <h3 class="modal-title">作成内容の確認</h3>
            <p class="modal-desc">
              以下 <strong data-bulk-create-target="previewCount"></strong> 件のレコードを作成します。よろしいですか？
            </p>
            <div class="bulk-create-records">
              <table class="modal-records-table">
                <thead>
                  <tr>
                    <th>学籍番号</th>
                    <th>授業コード</th>
                    <th>授業日</th>
                    <th>状態</th>
                    <th>備考</th>
                  </tr>
                </thead>
                <tbody data-bulk-create-target="previewBody"></tbody>
              </table>
            </div>

            <%= form_with url: bulk_create_attendances_path,
                          method: :post,
                          data: { bulk_create_target: "form" } do %>
            <% end %>

            <div class="modal-actions">
              <button type="button"
                      class="btn ghost"
                      data-action="click->bulk-create#back">← 戻る</button>
              <button type="button"
                      class="btn primary"
                      data-action="click->bulk-create#send">作成する</button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <div data-controller="report-confirm">
      <%= form_with url: attendance_reports_path, method: :post,
            class: "inline-form",
            data: { report_confirm_target: "form" } do |f| %>
        <% @q_params.each do |key, value| %>
          <%= hidden_field_tag "q[#{key}]", value %>
        <% end %>
        <button type="button"
                class="btn ghost btn--sm"
                data-action="click->report-confirm#open">レポート送信</button>
      <% end %>

      <div data-report-confirm-target="modal"
           class="modal-overlay hidden"
           data-action="click->report-confirm#backdropClose">
        <div class="modal" data-action="click->report-confirm#stopPropagation">
          <h3 class="modal-title">レポート送信の確認</h3>
          <p class="modal-desc">以下の条件でメールを送信します。よろしいですか？</p>
          <dl class="modal-summary">
            <dt>学籍番号</dt>
            <dd><%= @q_params[:student_code_eq].presence || "すべて" %></dd>
            <dt>授業コード</dt>
            <dd><%= @q_params[:lesson_code_eq].presence || "すべて" %></dd>
            <dt>状態</dt>
            <dd>
              <% if (sv = @q_params[:status_eq]).present? %>
                <% key = Attendance.statuses.key(sv.to_i) %>
                <%= key ? t("attendance.status.#{key}") : "すべて" %>
              <% else %>
                すべて
              <% end %>
            </dd>
            <dt>授業日</dt>
            <dd><%= @q_params[:date_eq].presence || "指定なし" %></dd>
            <dt>送信日</dt>
            <dd><%= @q_params[:created_on].presence || "指定なし" %></dd>
            <dt>対象件数</dt>
            <dd><strong><%= @attendances.size %> 件</strong></dd>
          </dl>

          <div class="modal-records">
            <table class="modal-records-table">
              <thead>
                <tr>
                  <th>学籍番号</th>
                  <th>授業コード</th>
                  <th>授業日</th>
                  <th>状態</th>
                  <th>備考</th>
                </tr>
              </thead>
              <tbody>
                <% @attendances_ordered.each do |a| %>
                  <tr>
                    <td class="td-code"><%= a.student_code %></td>
                    <td class="td-code td-sub"><%= a.lesson_code %></td>
                    <td><%= a.date %></td>
                    <td>
                      <span class="badge badge-<%= a.status %>">
                        <%= t("attendance.status.#{a.status}") %>
                      </span>
                    </td>
                    <td class="td-sub"><%= a.comment %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="modal-actions">
            <button type="button"
                    class="btn ghost"
                    data-action="click->report-confirm#close">キャンセル</button>
            <button type="button"
                    class="btn primary"
                    data-action="click->report-confirm#send">送信する</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= form_with url: bulk_destroy_attendances_path, method: :post,
        data: { controller: "select-all" } do |f| %>
    <div class="panel-head panel-head--sub">
      <button
        type="submit"
        class="btn ghost btn--sm btn--danger"
        data-turbo-confirm="選択したレコードを削除しますか？"
        data-action="click->select-all#bulkDestroy"
      >選択削除</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="th-check">
              <input
                type="checkbox"
                data-select-all-target="toggle"
                data-action="change->select-all#toggleAll"
              />
            </th>
            <th>学籍番号</th>
            <th>授業コード</th>
            <th>授業日</th>
            <th>状態</th>
            <th>備考</th>
            <th>送信日時</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="attendances-list">
          <% if @attendances.empty? %>
            <tr class="empty-row">
              <td colspan="8">レコードがありません</td>
            </tr>
          <% else %>
            <%= render @attendances %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<%= turbo_stream_from "attendances" %>
