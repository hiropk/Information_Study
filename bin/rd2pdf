#!/usr/bin/env bash
# Usage: bin/rd2pdf <file.rd> [output.pdf]
# Converts a Rabbit RD slide file to PDF.
# If output path is omitted, saves as docs/slides/<basename>.pdf

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SLIDES_OUT="$REPO_ROOT/docs/slides"

if [ $# -eq 0 ]; then
  echo "Usage: $(basename "$0") <file.rd> [output.pdf]" >&2
  exit 1
fi

INPUT="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"

if [ ! -f "$INPUT" ]; then
  echo "Error: file not found: $INPUT" >&2
  exit 1
fi

if [ $# -ge 2 ]; then
  OUTPUT="$(cd "$(dirname "$2")" && pwd)/$(basename "$2")"
else
  BASENAME="$(basename "${INPUT%.rd}")"
  OUTPUT="$SLIDES_OUT/${BASENAME}.pdf"
fi

mkdir -p "$(dirname "$OUTPUT")"

echo "Converting: $INPUT → $OUTPUT"
cd "$REPO_ROOT/slides" && bundle exec rabbit --print --size=1024,768 --output-filename="$OUTPUT" "$INPUT"
echo "Done: $OUTPUT"
